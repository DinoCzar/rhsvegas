PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=24h
DATABASE_PATH=./data/rhsvegas.db

# Comma-separated origins allowed for CORS (your website URL)
FRONTEND_ORIGINS=http://localhost:8080,https://rhsvegas.com,https://www.rhsvegas.com

# First admin account (used by npm run seed)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Ryan

# Business notifications
OWNER_EMAIL=you@example.com
BUSINESS_NAME=Ryan's Home Solutions
TIMEZONE=America/Los_Angeles

# Email — required for booking notifications (owner + customer)
# Without these, checkout still works but no emails are sent.
#
# Yahoo Mail example:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@yahoo.com
#   SMTP_PASS=your-app-password   (Yahoo Account → Security → App passwords)
#   SMTP_FROM=yourname@yahoo.com    (must match SMTP_USER for Yahoo)
#   OWNER_EMAIL=yourname@yahoo.com  (where new booking alerts go)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rhsvegas.com
