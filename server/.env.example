PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=24h

# Local dev: SQLite file (no Turso credentials needed)
DATABASE_PATH=./data/rhsvegas.db

# Production on Render: Turso cloud database (free tier)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Comma-separated origins allowed for CORS (your website URL)
FRONTEND_ORIGINS=http://localhost:8080,https://rhsvegas.com,https://www.rhsvegas.com

# First admin account (used by npm run seed)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Ryan
# Set to true only when intentionally resetting the admin password from env (production default: false)
ADMIN_SYNC_PASSWORD=false

# Business notifications
OWNER_EMAIL=you@example.com
BUSINESS_NAME=Ryan's Home Solutions
TIMEZONE=America/Los_Angeles

# Email — required for booking notifications (owner + customer)
#
# Production on Render: use Resend (Render blocks outbound SMTP to Yahoo/Gmail).
# 1. Sign up at https://resend.com
# 2. Add and verify domain rhsvegas.com (DNS records in GoDaddy)
# 3. Create an API key
RESEND_API_KEY=
EMAIL_FROM=bookings@rhsvegas.com
#
# Local dev only — SMTP works on localhost but not on Render:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=yourname@yahoo.com
# SMTP_PASS=your-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rhsvegas.com
